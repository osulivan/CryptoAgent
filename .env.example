# ============================================
# HTTP 代理配置（可选）
# 如果访问 OKX API 需要代理，请取消注释并配置
# ============================================
# HTTP_PROXY=http://127.0.0.1:10080
# HTTPS_PROXY=http://127.0.0.1:10080

# ============================================
# 服务配置
# ============================================
# API服务端口（管理界面）
API_SERVICE_PORT=8000

# Agent服务端口（执行Agent）
AGENT_SERVICE_PORT=8001

# Agent服务地址（API服务调用Agent服务时使用）
AGENT_SERVICE_URL=http://localhost:8001

# API服务地址（Agent服务回调API服务时使用）
API_SERVICE_URL=http://localhost:8000
